# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@db:5432/flagfootball

# Clerk Authentication
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev/
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key-here

# Frontend Configuration (Next.js — apps/web/)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key-here

# reCAPTCHA (Google reCAPTCHA v3)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key

# CORS — add Vercel production URL when deployed
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
RECAPTCHA_SECRET_KEY=your-recaptcha-v2-secret-key

# Contact form destination email (defaults to ADMIN_EMAIL if not set)
CONTACT_EMAIL=your-contact-email@example.com

# Resend (transactional email)
RESEND_API_KEY=re_your-resend-api-key-here
EMAIL_FROM=onboarding@resend.dev
